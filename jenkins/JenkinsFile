pipeline {

    agent any

    stages {

        stage('Clone Repository') {

            steps {
                git 'https://github.com/Abhayab24/CloudNest.git'
            }
        }

        stage('Build Containers') {

            steps {
                sh 'docker compose build'
            }
        }

        stage('Run Containers') {

            steps {
                sh 'docker compose up -d'
            }
        }
    }
}